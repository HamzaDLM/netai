# log_ingestor environment skeleton
# Copy to log_ingestor/.env for local runs if you need overrides.

RUST_LOG=info

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=syslogs
KAFKA_GROUP_ID=log-ingestor

CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=netops
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=admin
CLICKHOUSE_RETENTION_DAYS=30
CLICKHOUSE_BATCH_SIZE=1000
CLICKHOUSE_FLUSH_INTERVAL_MS=1000
CLICKHOUSE_INSERT_QUEUE_CAPACITY=20000

# Comma-separated and/or newline-separated substrings to drop before normalization.
IGNORED_SYSLOG_TEXTS=

# Legacy settings retained for compatibility with older flows and shared components.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=syslogs
EMBEDDING_URL=http://localhost:8080/openai/embed
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECS=30
EMBEDDING_DIMENSION=1536
EMBEDDING_MAX_IN_FLIGHT=4
EMBEDDING_MAX_REQUESTS_PER_SECOND=4
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_BACKOFF_MS=250

REDIS_URL=
VENDOR_LOOKUP_URL=
VENDOR_REFRESH_SECS=900
VENDOR_CACHE_PREFIX=vendor_cache
